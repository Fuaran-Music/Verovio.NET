<?xml version="1.0" encoding="utf-8"?>
<!--
  Two-feed wiring per the workspace CLAUDE.md "GitHub org and Packages feed"
  section. Verovio.NET produces public-facing NuGet packages once the OSS
  flag flips, but during bootstrap it ships through the same private channels
  as the rest of the family:

    - `local` shadows the released feed for inner-loop iteration; populated
       by `run.ps1 -Pack` packing into ..\local-nuget-feed\.
    - `github-fuaran-music` serves the `Verovio.NET.*` packages this repo
       produces (consumed by `fuaran-music/`'s Renderer.Engraving in Phase
       05, then by the other consumer siblings).

  packageSourceMapping is REQUIRED here because central package management
  is on (Directory.Packages.props sets ManagePackageVersionsCentrally), and
  CPM with > 1 declared source errors out (NU1507) without an explicit
  mapping. Mapping `*` to nuget.org means every public package goes there;
  the Verovio.NET.* entries route the adapter packages to the right private
  feed when those references land. The `local` source is mapped
  permissively so the inner-loop pack workflow can shadow them.
-->
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="local" value="..\..\local-nuget-feed" />
    <add key="github-fuaran-music" value="https://nuget.pkg.github.com/Fuaran-Music/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="local">
      <package pattern="Verovio.NET*" />
      <package pattern="Fuaran.*" />
    </packageSource>
    <packageSource key="github-fuaran-music">
      <package pattern="Verovio.NET*" />
    </packageSource>
  </packageSourceMapping>
  <packageSourceCredentials>
    <github-fuaran-music>
      <add key="Username" value="%GITHUB_PACKAGES_USER%" />
      <add key="ClearTextPassword" value="%GITHUB_PACKAGES_TOKEN%" />
    </github-fuaran-music>
  </packageSourceCredentials>
</configuration>
